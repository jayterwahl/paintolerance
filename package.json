{
  "name": "pain-tolerance",
  "version": "1.0.0",
  "private": true,
  "description": "Simulated hostile replies on your own tweets to build up your pain tolerance for internet nonsense.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "typecheck": "tsc --noEmit",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "clean": "wxt clean",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "wxt": "^0.20.25"
  }
}
